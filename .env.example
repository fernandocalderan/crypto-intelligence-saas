APP_ENV=development
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/crypto_intelligence
REDIS_URL=redis://localhost:6379/0
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-api-secret
COINGLASS_API_KEY=your-coinglass-api-key
AUTH_SECRET=replace-with-a-long-random-secret
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_PRO_PLUS=price_pro_plus_placeholder
ENABLE_STRIPE_MOCK_CHECKOUT=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SIGNAL_ENGINE_USE_MOCK_DATA=false
MARKET_DATA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,DOGEUSDT,XRPUSDT
MARKET_DATA_SCHEDULE_MINUTES=5
MARKET_DATA_USE_MOCK_FALLBACK=true
ENABLE_MARKET_DATA_SCHEDULER=true
MARKET_DATA_RUN_INITIAL_SYNC=true
ENABLE_BINANCE_MARKET_DATA=true
ENABLE_BYBIT_MARKET_DATA=true
ENABLE_COINGLASS_MARKET_DATA=false
ENABLE_VOLUME_SPIKE_SIGNAL=true
ENABLE_RANGE_BREAKOUT_SIGNAL=true
ENABLE_FUNDING_EXTREME_SIGNAL=true
ENABLE_OI_DIVERGENCE_SIGNAL=true
ENABLE_LIQUIDATION_CLUSTER_SIGNAL=true
ENABLE_ALERTS=true
ENABLE_TELEGRAM_ALERTS=true
ENABLE_EMAIL_ALERTS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
ALERT_MIN_SCORE=6.5
ALERT_MIN_CONFIDENCE=0.55
ALERT_DEDUPE_WINDOW_MINUTES=5
ALERT_MAX_PER_RUN=50
ALERTS_PROCESS_ON_SCHEDULER=true
ENABLE_CONFLUENCE_ENGINE=true
ALERT_ON_INDIVIDUAL_SIGNALS=false
MIN_SETUP_SCORE=6.5
MIN_SETUP_CONFIDENCE=55
EARLY_SIGNAL_MIN_SCORE=7.2
EARLY_SIGNAL_MIN_CONFIDENCE=0.65
EARLY_SIGNAL_MAX_PER_RUN=2
EARLY_SIGNAL_COOLDOWN_HOURS=8
SETUP_REQUIRE_NO_MOCK_FOR_EXECUTABLE=true
